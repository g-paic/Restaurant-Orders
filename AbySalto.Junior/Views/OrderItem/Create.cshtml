@model OrderItem

@{
    ViewData["Title"] = "Novi artikal";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Novi artikal</h2>
            </div>
        </div>
    </div>
    
    <div class="card-body p-4">
        <form method="post" class="row">
            <div class="border p-3">
                <input type="hidden" asp-for="OrderId" value="@ViewBag.OrderId" />
                
                <div class="form-floating py-2 col-12">
                    <input asp-for="Name" class="form-control border-0 shadow" />
                    <label asp-for="Name" class="ms-2">Naziv</label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="Quantity" class="form-control border-0 shadow" />
                    <label asp-for="Quantity" class="ms-2">Količina</label>
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="Price" class="form-control border-0 shadow" />
                    <label asp-for="Price" class="ms-2">Cijena</label>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="row pt-2">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Spremi</button>
                    </div>
                    
                    <div class="col-6 col-md-3">
                        <a asp-controller="OrderItem" asp-action="Items" asp-route-id="@ViewBag.OrderId" class="btn btn-info form-control">Natrag</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
